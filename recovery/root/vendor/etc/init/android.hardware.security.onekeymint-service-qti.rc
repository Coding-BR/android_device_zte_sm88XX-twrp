#
# MODIFIED: Add disabled and remove on-init start.
# KeyMint must start AFTER qseecomd listener is registered,
# otherwise channel enters broken state (TEE not ready).
# init.recovery.qcom.rc starts it on vendor.sys.listeners.registered=true.

service vendor.keymint /vendor/bin/hw/android.hardware.security.onekeymint-service-qti
    class early_hal
    disabled
    user system
    seclabel u:r:recovery:s0