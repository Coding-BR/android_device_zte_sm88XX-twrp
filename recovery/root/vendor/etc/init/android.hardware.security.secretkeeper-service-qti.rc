#
# MODIFIED for TWRP recovery:
# - Disabled by default; started by init.recovery.qcom.rc once TEE is ready.
# - Required for synthetic-password / Weaver based FBE decryption on sm8850.

service vendor.secretkeeper /vendor/bin/hw/android.hardware.security.secretkeeper-service-qti
    class hal
    user root
    group drmrpc
    disabled
    seclabel u:r:recovery:s0
