#
# MODIFIED for TWRP recovery:
# - Keep disabled; do NOT start on init.
# - init.recovery.qcom.rc starts this after qseecomd listeners are registered.
# - Aligned with normal system config (gatekeeper-rust-service-qti, non-SPU path).

service vendor.gatekeeper_default /vendor/bin/hw/android.hardware.gatekeeper-rust-service-qti
    class early_hal
    user root
    group root
    setenv LD_LIBRARY_PATH /vendor/lib64:/vendor/lib64/hw:/system/lib64:/sbin:/odm/lib64
    disabled
    seclabel u:r:recovery:s0
