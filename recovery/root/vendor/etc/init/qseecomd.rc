#
# MODIFIED for TWRP recovery:
# - Do NOT start on init; smcinvoke/qseecom permissions are not ready yet.
# - init.recovery.qcom.rc starts this after modules load and permissions are set.

service vendor.qseecomd /vendor/bin/qseecomd
    socket notify-topology stream 660 system drmrpc
    class core
    user root
    group root drmrpc
    disabled
    seclabel u:r:recovery:s0

on property:vendor.car.hiber=hiberExit
   stop vendor.qseecomd
   start vendor.qseecomd
